# Frontend Environment Variables (Vite)
# Copy this file to .env.local for local development
# Set these in Vercel environment variables for production

# Backend API URL
# Development: http://localhost:8000/api
# Production: https://your-backend-url.onrender.com/api
VITE_API_URL=http://localhost:8000/api

# Hero illustration (Local Transparent PNG)
# Example: /hero-plant.png
VITE_HERO_FREEPIK_URL=/hero-plant.png

# Optional attribution link for the selected illustration
VITE_HERO_FREEPIK_CREDIT_URL=https://www.freepik.com/free-psd/lush-green-plant-white-pot-perfect-home-decor_406467762.htm
