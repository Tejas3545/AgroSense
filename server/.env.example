# Plant Care Backend Configuration

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Hugging Face Inference API (recommended for plant disease detection)
# Get your key: https://huggingface.co/settings/tokens
# Specialized model for plant disease identification and detection
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# Best model: linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification
# Detects 38+ plant diseases with high accuracy
HUGGINGFACE_MODEL=linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification

# Google Gemini API (recommended for best plant analysis)
# Get your key: https://ai.google.dev/ (Google Generative AI)
GEMINI_API_KEY=your_gemini_api_key_here
# Model: gemini-2.0-flash-exp (latest, fast, accurate)
GEMINI_MODEL=gemini-2.5-flash

# OpenWeather API (for weather data)
# Get your key: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Plant.id API (optional alternative for plant disease detection)
# Get your key: https://web.plant.id/
PLANT_ID_API_KEY=your_plant_id_api_key_here

# Security Configuration
# Generate a secure secret key for session management
SECRET_KEY=your_secure_random_secret_key_here

# Flask Configuration
FLASK_ENV=development
DEBUG=True

# CORS Settings (comma-separated list of allowed origins or * for all)
# Development: http://localhost:5173,http://localhost:3000
# Production: Add your Vercel domain: https://your-app.vercel.app
# Use * to allow all origins (not recommended for production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://agrosense-health.vercel.app

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# File Upload Settings
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes
UPLOAD_FOLDER=uploads/
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif

# Cache Settings (optional)
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# Database (if needed in future)
# DATABASE_URL=sqlite:///plant_care.db
# Or for PostgreSQL: postgresql://user:password@localhost/dbname

# Redis (for advanced caching, optional)
# REDIS_URL=redis://localhost:6379/0

# Email Configuration (for notifications, optional)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_email_password

# Monitoring and Analytics (optional)
# SENTRY_DSN=your_sentry_dsn_here
# GOOGLE_ANALYTICS_ID=your_ga_id_here
